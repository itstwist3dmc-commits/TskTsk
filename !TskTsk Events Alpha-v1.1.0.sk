# TskTsk Events

# On Entity Dye
import:
    io.papermc.paper.event.entity.EntityDyeEvent
event "EntityDyeEvent": # Cancellable
    patterns:
        [on] dye [(of %entitydatas%)] 
        [on] [(%entitydatas%)] dye
    event-values: player, color, entity
    check:
        if expr-1 is set:
            if all:
                event-entity is not sheep
                event-entity is not cat
                event-entity is not tamed wolf
            then:
                stop
            else if event-entity isn't expr-1:
                expr-1 is set
                stop
            continue
        else if expr-1 is set:
            continue
on EntityDyeEvent:
    set {_eventValues::entity} to event.getEntity()
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::color} to event.getColor()
    set {_event} to (custom event "EntityDyeEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)
        if event.getEntity() is tamed wolf:
            set the color of event.getEntity() to event.getEntity()'s color # Wolf Cancel Event Desync Fix || I know this looks like nonsense lol, bear with me.

# Block Dispense Loot/Item

import:
    org.bukkit.event.block.BlockDispenseLootEvent

event "BlockDispenseLootEvent": # Cancellable
    patterns:
        [on] block dispense loot[-| ][table]
    event-values: loot table, player, item

on BlockDispenseLootEvent:
    set {_eventValues::lootTable} to event.getLootTable()
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::item} to event.DispensedLoot()
    set {_event} to (custom event "BlockDispenseLootEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)


# Strider Temperature Change

import:
    org.bukkit.event.entity.StriderTemperatureChangeEvent as StriderTempChange

event "StriderTempChange":
    patterns:
        [on] strider temp[erature] change
    event-values: entity, boolean # If the strider is shivering

on StriderTempChange:
    set {_eventValues::entity} to event.getEntity()
    set {_eventValues::boolean} to event.isShivering()
    set {_event} to (custom event "StriderTempChange" using event-values {_eventValues::*})
    call {_event}


# Villager Acquire Trade

import:
    org.bukkit.event.entity.VillagerAcquireTradeEvent as AcquireTrade

event "AcquireTrade":
    patterns:
        [on] [villager] acquire [new] trade
        [on] [merchant] acquire [new] trade
    event-values: entity, merchantRecipe
    
on AcquireTrade:
    set {_eventValues::entity} to event.getEntity()
    set {_eventValues::recipe} to event.getRecipe()
    broadcast {_eventValues::*}
    set {_event} to (custom event "AcquireTrade" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)


