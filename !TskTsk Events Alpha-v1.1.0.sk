# Player Shear Block (Not to be confused with Shear Entity, this event is called when using shears on a block. ex: Shearing glowberries)

import:
    io.papermc.paper.event.block.PlayerShearBlockEvent

event "PlayerShearBlockEvent":
    patterns:
        [on] [player] shear[ing] [a] block
        [on] [player] shear[ing] [a|an] %blockdata%
    event-values: player, block, itemStack, equipmentslot, itemStacks
    check:
        if expr-1 is set:
            expr-1 = event.getBlock():
                continue

on PlayerShearBlockEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::block} to event.getBlock()
    set {_eventValues::itemStack} to event.getItem()
    set {_eventValues::equipmentslot} to event.getHand()
    set {_eventValues::itemStacks} to event.getDrops()
    set {_event} to (custom event "PlayerShearBlockEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)

# Player Shield Disable

import:
    io.papermc.paper.event.player.PlayerShieldDisableEvent

event "PlayerShieldDisableEvent":
    patterns:
        [on] [player] shield disabl(e|ing)
    event-values: player, entity, integer

on PlayerShieldDisableEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::entity} to event.getDamager()
    set {_eventValues::integer} to event.getCooldown()
    set {_event} to (custom event "PlayerShieldDisableEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)

# Player Show Entity (This event is only called when the entity's visibility status is actually changed. This event is called regardless of whether the entity was within tracking range.)  

import:
    org.bukkit.event.player.PlayerShowEntityEvent

event "PlayerShowEntityEvent":
    patterns:
        [on] [player] show[ing] [of] entity
        [on] [player] show[ing] [of] %entitydata%
    event-values: player, entity
    check:
        if expr-1 is set:
            expr-1 = event.getEntity():
                continue

on PlayerShowEntityEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::entity} to event.getEntity()
    set {_event} to (custom event "PlayerShowEntityEvent" using event-values {_eventValues::*})
    call {_event}

# Statistic Increment Event

import:
    org.bukkit.event.player.PlayerStatisticIncrementEvent

event "PlayerStatisticIncrementEvent":
    patterns:
        [on] [player] stat[s|istic[s]] increment[ing]
    event-values: player, statistic, integer, integer, material, entityType

on PlayerStatisticIncrementEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::statistic} to event.getStatistic()
    set {_eventValues::integer::initialValue} to event.getOldValue()
    set {_eventValues::integer::newValue} to event.getNewValue()
    set {_eventValues::material} to event.getMaterial()
    set {_eventValues::entityType} to event.getEntityType()
    set {_event} to (custom event "PlayerStatisticIncrementEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)

# Take Lecern Book Event

import:
    org.bukkit.event.player.PlayerTakeLecternBookEvent

event "PlayerTakeLecternBookEvent":
    patterns:
        [on] [player] tak(e|ing) lectern book [at %locations%]
    event-values: player, block, location
    check:
        if exprs-1 is set:
            loop exprs-1:
                loop-value = (location of event.getLectern()):
                    continue

on PlayerTakeLecternBookEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::block} to event.getLectern()
    set {_eventValues::location} to (location of event.getLectern())
    set {_event} to (custom event "PlayerTakeLecternBookEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)

# Toggle Entity Age Lock (Version 26.1+, called when a player used a golden dandelion on a baby entity)

import:
    io.papermc.paper.event.player.PlayerToggleEntityAgeLockEvent # If your server version isn't on 26.1+, ignore this error.

event "PlayerToggleEntityAgeLockEvent":
    patterns:
        [on] [player] toggl(e|ing) entity['s] age lock
        [on] [player] toggl(e|ing) %entitydata%['s] age lock
    event-values: player, livingEntity, itemStack, equipmentslot, boolean

on PlayerToggleEntityAgeLockEvent: # If your server version isn't on 26.1+, ignore this error.
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::livingEntity} to event.getEntity()
    set {_eventValues::itemStack} to event.getItem()
    set {_eventValues::equipmentslot} to event.getHand()
    set {_eventValues::boolean} to event.isAgeLocked()
    set {_event} to (custom event "PlayerToggleEntityAgeLockEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)

# Player Untrack Entity (not to be confused with SkBee's track entity, this event is called when a Player untracks an Entity.)

import:
    io.papermc.paper.event.player.PlayerUntrackEntityEvent

event "PlayerUntrackEntityEvent":
    patterns:
        [on] [player] untrack[ing] entity
        [on] [player] entity untrack[ing]
        [on] [player] untrack[ing] %entitydata%
        [on] [player] %entitydata% untrack[ing]
    event-values: player, entity
    check:
        if expr-1 is set:
            expr-1 = event.getEntity():
                continue

on PlayerUntrackEntityEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::entity} to event.getEntity()
    set {_event} to (custom event "PlayerUntrackEntityEvent" using event-values {_eventValues::*})
    call {_event}

