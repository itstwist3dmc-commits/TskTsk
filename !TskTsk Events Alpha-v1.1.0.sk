# Hide Entity

import:
    org.bukkit.event.player.PlayerHideEntityEvent

event "PlayerHideEntityEvent":
    patterns:
        [on] [player] hid(e|ing) [[of] %entitydata%]
    event-values: player, entity
    check:
        if expr-1 is set:
            if event.getEntity() = expr-1:
                continue
            else if event.getEntity() != expr-1:
                stop

on PlayerHideEntityEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::entity} to event.getEntity()
    set {_event} to (custom event "PlayerHideEntityEvent" using event-values {_eventValues::*})
    call {_event}

