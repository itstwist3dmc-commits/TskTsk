event "AbstractRespawnEvent":
    patterns:
        [on] abstract respawn
    event-values: player, location, boolean, boolean, boolean, string

on AbstractRespawnEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::location} to event.getRespawnLocation()
    set {_eventValues::boolean::isBedSpawn} to event.isBedSpawn()
    set {_eventValues::boolean::isAnchorSpawn} to event.isAnchorSpawn()
    set {_eventValues::boolean::missingRespawnBlock} to event.isMissingRespawnBlock()
    set {_eventValues::string} to event.isMissingRespawnBlock()
    set {_event} to (custom event "AbstractRespawnEvent" using event-values {_eventValues::*})
    call {_event}

