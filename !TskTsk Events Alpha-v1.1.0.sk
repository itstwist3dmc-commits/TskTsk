# Lectern Page Change Event

import:
    io.papermc.paper.event.player.PlayerLecternPageChangeEvent

event "PlayerLecternPageChangeEvent":
    patterns:
        [on] [player] lectern page chang(e|ing) [l:left|r:right]
    event-values: player, block, itemStack, direction, integer, integer
    check:
        if first element of parse tags contains "l":
            if event.getPageChangeDirection() = left:
                stop
        else if first element of parse tags contains "r":
            if event.getPageChangeDirection() = right:
                stop

on PlayerLecternPageChangeEvent:
    set {_eventValues::player} to event.getPlayer()
    set {_eventValues::block} to event.getLectern()
    set {_eventValues::itemStack} to event.getBook()
    set {_eventValues::direction} to event.getPageChangeDirection()
    set {_eventValues::integer::oldPage} to event.getOldPage()
    set {_eventValues::integer::newPage} to event.getNewPage()
    set {_event} to (custom event "PlayerLecternPageChangeEvent" using event-values {_eventValues::*})
    call {_event}
    if {_event}.isCancelled():
        cancel event
        event.setCancelled(true)

