# Server Full Check

import:
    io.papermc.paper.event.player.PlayerServerFullCheckEvent

event "PlayerServerFullCheckEvent":
    patterns:
        [on] [player] server full[ |-]check
    event-values: object, string, boolean

on PlayerServerFullCheckEvent:
    set {_eventValues::object} to event.getPlayerProfile()
    if event.isAllowed() is false:
        set {_eventValues::string} to event.deny()
    else if event.isAllowed() is true:
        set {_eventValues::string} to event.allow()
    set {_eventValues::boolean} to event.isAllowed()
    set {_event} to (custom event "PlayerServerFullCheckEvent" using event-values {_eventValues::*})
    call {_event}

